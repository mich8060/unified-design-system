{
  "name": "@mich8060/unified-design-system",
  "private": false,
  "version": "0.2.8",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chghealthcare/unified-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/chghealthcare/unified-design-system/issues"
  },
  "homepage": "https://github.com/chghealthcare/unified-design-system#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/design-system/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/design-system/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/unified-design-system.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "dev": "vite --configLoader native",
    "build": "vite build --configLoader native && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "preview": "vite preview --configLoader native",
    "lint": "eslint .",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "format": "prettier . --write",
    "generate:component": "node scripts/create-component.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "sass:watch": "sass --watch src/design-system:src/design-system"
  },
  "dependencies": {
    "prismjs": "^1.30.0",
    "prop-types": "^15.8.1"
  },
  "peerDependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router-dom": "^6.26.2 || ^7.0.0"
  },
  "codeConnect": {
    "parser": "react"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@figma/code-connect": "^1.3.9",
    "@phosphor-icons/react": "^2.1.10",
    "@storybook/addon-a11y": "^8.6.17",
    "@storybook/addon-docs": "^8.6.17",
    "@storybook/addon-links": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "dotenv": "^16.6.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^17.3.0",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "sass": "^1.78.0",
    "storybook": "^8.6.0",
    "stylelint": "^16.9.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.4.1"
  }
}
