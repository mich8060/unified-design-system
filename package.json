{
  "name": "@mich8060/unified-design-system",
  "version": "0.1.11",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chghealthcare/unified-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/chghealthcare/unified-design-system/issues"
  },
  "homepage": "https://github.com/chghealthcare/unified-design-system#readme",
  "main": "./dist/uds-components.umd.js",
  "module": "./dist/uds-components.es.js",
  "exports": {
    ".": {
      "import": "./dist/uds-components.es.js",
      "require": "./dist/uds-components.umd.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./*": {
      "import": "./dist/entries/*.js",
      "require": "./dist/entries/*.cjs"
    }
  },
  "files": [
    "dist",
    "src/ui",
    "src/styles"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@figma/code-connect": "^1.3.9",
    "@phosphor-icons/react": "^2.1.10",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^13.5.0",
    "dotenv": "^16.6.1",
    "node-fetch": "^3.3.2",
    "prismjs": "^1.30.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-router-dom": "^6.28.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "codeConnect": {
    "parser": "react"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:lib": "vite build --config vite.config.lib.js",
    "postbuild:lib": "node scripts/postbuild-lib-artifacts.cjs && node scripts/validate-public-tokens.cjs && node scripts/validate-runtime-exports.cjs",
    "build:lib:watch": "vite build --config vite.config.lib.js --watch",
    "publish:lib": "node scripts/publish-lib.js",
    "test": "react-scripts test",
    "test:spec-sync": "react-scripts test --watchAll=false --runTestsByPath src/ui/Button/Button.test.tsx src/ui/Accordion/Accordion.test.tsx src/ui/Input/Input.test.tsx src/ui/Dropdown/Dropdown.test.tsx src/ui/_spec/specStorySync.test.ts",
    "eject": "react-scripts eject",
    "codeconnect:publish": "code-connect publish",
    "codeconnect:unpublish": "code-connect unpublish",
    "sass:watch": "sass --watch src/styles/tokens.scss:src/styles/tokens.css src/styles/prism-custom.scss:src/styles/prism-custom.css",
    "typecheck": "tsc --noEmit",
    "validate:tokens": "node scripts/validate-public-tokens.cjs",
    "validate:runtime-exports": "node scripts/validate-runtime-exports.cjs",
    "test:consumer-fixture": "node scripts/verify-vite-consumer-fixture.cjs",
    "docs:spec-props": "node scripts/generate-spec-props-docs.cjs",
    "docs:storybook-ai": "node scripts/generate-storybook-ai-docs.cjs",
    "prestorybook": "npm run docs:storybook-ai",
    "prebuild-storybook": "npm run docs:storybook-ai",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "plugin:storybook/recommended"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.12",
    "@storybook/addon-docs": "^10.2.12",
    "@storybook/preset-create-react-app": "^10.2.12",
    "@storybook/react-webpack5": "^10.2.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint-plugin-storybook": "^10.2.12",
    "prettier": "3.8.1",
    "prop-types": "^15.8.1",
    "sass": "^1.97.3",
    "storybook": "^10.2.12",
    "typescript": "^4.9.5",
    "vite": "^5.4.0",
    "vite-plugin-svgr": "^4.5.0",
    "webpack": "^5.105.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
