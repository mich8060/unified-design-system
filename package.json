{
  "name": "@chg-ds/unified-design-system",
  "version": "1.0.0",
  "description": "React UI primitives and styles built with Tailwind CSS v4 and shadcn-style components (UDS).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chghealthcare/unified-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/chghealthcare/unified-design-system/issues"
  },
  "homepage": "https://github.com/chghealthcare/unified-design-system#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "AI_USAGE.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "volta": {
    "node": "22.22.2"
  },
  "keywords": [
    "react",
    "tailwind",
    "tailwindcss",
    "design-system",
    "components",
    "ui",
    "shadcn"
  ],
  "scripts": {
    "generate:ai": "node ./scripts/generate-ai-artifacts.mjs",
    "dev": "vite --config vite.config.docs.ts",
    "build": "npm run build:lib && npm run build:docs",
    "prepublishOnly": "npm run build:lib",
    "build:lib": "vite build --config vite.config.lib.ts && tsc -p tsconfig.lib.json && node ./scripts/prepare-package.mjs",
    "build:docs": "vite build --config vite.config.docs.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.lib.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "pack:check": "npm_config_cache=/tmp/uds-tailwind-test-npm-cache npm pack --dry-run",
    "preview": "vite preview --config vite.config.docs.ts",
    "ci:bundle": "node ./scripts/ci-bundle.mjs",
    "test:consumer-fixture": "node ./scripts/test-consumer-fixture.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.9.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "sass": "^1.99.0",
    "shadcn": "^4.2.0",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.4"
  }
}
