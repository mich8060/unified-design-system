{
  "name": "@mich8060/chg-design-system",
  "version": "0.1.9",
  "license": "UNLICENSED",
  "main": "./dist/uds-components.umd.js",
  "module": "./dist/uds-components.es.js",
  "exports": {
    ".": {
      "import": "./dist/uds-components.es.js",
      "require": "./dist/uds-components.umd.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./src/styles/tokens.css",
    "./Button": "./src/ui/Button/index.js",
    "./Calendar": "./src/ui/Calendar/index.js",
    "./Checkbox": "./src/ui/Checkbox/index.js",
    "./Input": "./src/ui/Input/index.js",
    "./Icon": "./src/ui/Icon/index.js",
    "./Avatar": "./src/ui/Avatar/index.js",
    "./Badge": "./src/ui/Badge/index.js",
    "./Chip": "./src/ui/Chip/index.js",
    "./Accordion": "./src/ui/Accordion/index.js",
    "./Dropdown": "./src/ui/Dropdown/index.js",
    "./Tabs": "./src/ui/Tabs/index.js",
    "./Table": "./src/ui/Table/index.js",
    "./Toggle": "./src/ui/Toggle/index.js",
    "./Radio": "./src/ui/Radio/index.js",
    "./Slider": "./src/ui/Slider/index.js",
    "./Toast": "./src/ui/Toast/index.js",
    "./Tooltip": "./src/ui/Tooltip/index.js",
    "./Flex": "./src/ui/Flex/index.js",
    "./Divider": "./src/ui/Divider/index.js",
    "./Tag": "./src/ui/Tag/index.js",
    "./Status": "./src/ui/Status/index.js",
    "./DotStatus": "./src/ui/DotStatus/index.js",
    "./Pagination": "./src/ui/Pagination/index.js",
    "./ProgressCircle": "./src/ui/ProgressCircle/index.js",
    "./ProgressIndicator": "./src/ui/ProgressIndicator/index.js",
    "./Field": "./src/ui/Field/index.js",
    "./Textarea": "./src/ui/Textarea/index.js",
    "./Datepicker": "./src/ui/Datepicker/index.js",
    "./FileUpload": "./src/ui/FileUpload/index.js",
    "./PillToggle": "./src/ui/PillToggle/index.js",
    "./Steps": "./src/ui/Steps/index.js",
    "./ImageAspect": "./src/ui/ImageAspect/index.js",
    "./Breadcrumb": "./src/ui/Breadcrumb/index.js",
    "./ActionMenu": "./src/ui/ActionMenu/index.js",
    "./Menu": "./src/ui/Menu/index.js",
    "./Card": "./src/ui/Card/index.js",
    "./Key": "./src/ui/Key/index.js",
    "./MicroCalendar": "./src/ui/MicroCalendar/index.js",
    "./Branding": "./src/ui/Branding/index.js",
    "./EventCard": "./src/ui/EventCard/index.js",
    "./UDS": "./src/ui/UDS/index.js"
  },
  "files": [
    "dist",
    "src/ui",
    "src/styles"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@figma/code-connect": "^1.3.9",
    "@phosphor-icons/react": "^2.1.10",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^13.5.0",
    "dotenv": "^16.6.1",
    "node-fetch": "^3.3.2",
    "prismjs": "^1.30.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-router-dom": "^6.28.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "codeConnect": {
    "parser": "react"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:lib": "vite build --config vite.config.lib.js",
    "build:lib:watch": "vite build --config vite.config.lib.js --watch",
    "publish:lib": "node scripts/publish-lib.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "tokens:generate": "node scripts/index.js",
    "tokens:validate": "node scripts/validate.js",
    "tokens:compile": "sass scripts/tokens.scss tokens/tokens.css",
    "tokens:watch": "sass --watch tokens/tokens.scss:tokens/tokens.css",
    "codeconnect:publish": "code-connect publish",
    "codeconnect:unpublish": "code-connect unpublish",
    "sass:watch": "sass --watch src/styles/tokens.scss:src/styles/tokens.css src/styles/prism-custom.scss:src/styles/prism-custom.css"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "prettier": "3.8.1",
    "sass": "^1.97.3",
    "vite": "^5.4.0",
    "vite-plugin-svgr": "^4.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
